      "id": 41,
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull"] }, "tooltip": { "mode": "multi" } },
      "targets": [{ "expr": "sum by (reason) (rate(personal_assistant_guidance_requests_total[5m]))", "legendFormat": "{{ reason }}", "refId": "A" }],
