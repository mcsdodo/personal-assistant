    {
      "title": "Processing Traces",
      "description": "All traces containing actual processing work (polling-only traces excluded). Click a Trace ID to view the full span timeline.",
      "type": "table",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 49 },
      "id": 40,
      "datasource": { "type": "tempo", "uid": "P214B5B846CF3925F" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "tempo", "uid": "P214B5B846CF3925F" },
          "queryType": "traceqlSearch",
          "limit": 50,
          "filters": [
            {
              "id": "span-name",
              "tag": "name",
              "operator": "=~",
              "value": ["workflow.execute_job", "invoice-worker.execute", "scan-worker.execute", "email-watcher.job_created", "gdrive-watcher.job_created", "workflow.job_created"],
              "valueType": "string",
              "scope": "span"
            },
            {
              "id": "service-name",
              "tag": "service.name",
              "operator": "=",
              "value": ["personal-assistant"],
              "valueType": "string",
              "scope": "resource"
            }
          ]
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": { "type": "auto" },
            "inspect": false
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Trace ID" },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "View full trace",
                    "url": "/explore?schemaVersion=1&panes=%7B%22t%22%3A%7B%22datasource%22%3A%22P214B5B846CF3925F%22%2C%22queries%22%3A%5B%7B%22refId%22%3A%22A%22%2C%22queryType%22%3A%22traceql%22%2C%22query%22%3A%22${__value.raw}%22%7D%5D%2C%22range%22%3A%7B%22from%22%3A%22now-1h%22%2C%22to%22%3A%22now%22%7D%7D%7D",
                    "targetBlank": true
                  }
                ]
              }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Duration" },
            "properties": [
              { "id": "unit", "value": "ms" }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Start time", "desc": true }]
      }
    },
    {
      "datasource": { "type": "prometheus", "uid": "${prometheus_ds}" },
      "description": "Rate of job pauses into awaiting_user_guidance, grouped by trigger reason (classifier_unknown, encrypted_pdf, ...). Rising classifier_unknown → Haiku over-using 'I don't know'. Rising encrypted_pdf → wrong bank password. Source metric emitted by workflow-mcp.ts on every pauseAndNotify call.",
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 60 }, "unit": "short" } },
