{
  "mcpServers": {
    "email-watcher": {
      "command": "bun",
      "args": ["run", "/app/channels/email-watcher.ts"]
    },
    "gdrive-watcher": {
      "command": "bun",
      "args": ["run", "/app/channels/gdrive-watcher.ts"]
    },
    "telegram": {
      "command": "bun",
      "args": ["run", "/app/channels/telegram/server.ts"]
    },
    "workflow": {
      "command": "bun",
      "args": ["run", "/app/channels/workflow-mcp.ts"]
    },
    "paperless": {
      "type": "http",
      "url": "http://paperless-mcp:3000/mcp"
    },
    "checker": {
      "type": "http",
      "url": "http://checker-mcp:8001/mcp"
    },
    "gmail": {
      "type": "http",
      "url": "http://gmail-mcp:8000/mcp"
    },
    "outlook": {
      "type": "http",
      "url": "http://outlook-mcp:8002/mcp"
    }
  }
}
