# Paperless-ngx API
PAPERLESS_URL=https://documents.lacny.me
PAPERLESS_API_TOKEN=your-paperless-api-token

# Gmail (google_workspace_mcp)
# Get from Google Cloud Console → OAuth 2.0 Client ID (Desktop App type)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
# Place client_secret.json in data/gmail/
# GMAIL_CREDS_DIR=./data/gmail

# Outlook/M365 (ms-365-mcp-server)
# Uses built-in public client app by default — no config needed
# For custom Azure app: set MS365_MCP_CLIENT_ID
# MS365_MCP_CLIENT_ID=your-azure-client-id

# Telegram channel (two-way notifications)
# Create bot via @BotFather, paste token here
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_BOT_NAME=your_bot_name
# TELEGRAM_CHAT_ID=-your-group-chat-id

# Windows local dev
# CLAUDE_CONFIG_DIR=C:/Users/Dodo/.claude

# Email-watcher channel
GMAIL_EMAIL=lacny.jozef@gmail.com
GMAIL_SEARCH_QUERY=newer_than:1d
OUTLOOK_ENABLED=true
POLL_INTERVAL_MS=30000
# STARTUP_DELAY_MS=15000
# MAX_NEW_PER_CYCLE=5
