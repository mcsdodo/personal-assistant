# Paperless-ngx API (local dev instance on port 8010)
PAPERLESS_URL=http://paperless:8000
PAPERLESS_API_TOKEN=your-paperless-api-token

# Gmail (google_workspace_mcp)
# Get from Google Cloud Console → OAuth 2.0 Client ID (Desktop App type)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret
# Full client_secret.json content (production: written to file at container start)
# GOOGLE_CLIENT_SECRET_JSON={"installed":{"client_id":"...","client_secret":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","redirect_uris":["http://localhost"]}}

# Outlook (outlook-mcp, MSAL device code auth)
AZURE_CLIENT_ID=your-azure-client-id

# Telegram channel (two-way notifications)
# Create bot via @BotFather, paste token here
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# TELEGRAM_BOT_NAME=your_bot_name
# TELEGRAM_CHAT_ID=your-chat-id  # DM chat ID (positive), or group chat ID (negative)

# Windows local dev
# CLAUDE_CONFIG_DIR=~/.claude
# DOWNLOADS_DIR=./data/downloads
# EMAIL_WATCHER_DATA_DIR=./data/email-watcher
# OUTLOOK_DATA_DIR=./data/outlook

# Email-watcher channel
GMAIL_EMAIL=your_email@gmail.com
# Gmail search base query (time filtering is automatic via last_checked).
# For dev/testing, filter to a +alias to avoid processing real inbox:
#   GMAIL_SEARCH_BASE=to:your_email+dev@gmail.com
GMAIL_SEARCH_BASE=
# How far back to check for emails on first poll for a brand-new source.
# Replaces the old first_start Telegram prompt. Format: '3d', '1w', '24h', '12h'.
INITIAL_LOOKBACK=3d
# Flood backstop (NOT the per-poll batch size — that's MAX_NEW_PER_CYCLE=5).
# If a single poll cycle ever surfaces more than this many genuinely-new emails
# for one source (e.g. first deploy with a wide INITIAL_LOOKBACK, or recovery
# after a long outage), the poller fails loud — logs ERROR, emits the
# email_watcher.catchup_overflow{source=...} OTel counter, and does NOT advance
# last_checked. The operator then raises this or runs the skip-catchup CLI:
#   docker exec personal-assistant-email-poller bun /app/email-poller/cli/skip-catchup.ts gmail
# Must stay BELOW the 200-email page size or it can never fire (a poll never
# returns more than one page). Bursts up to this cap drain MAX_NEW_PER_CYCLE/poll.
MAX_CATCHUP_EMAILS=150
OUTLOOK_ENABLED=true
POLL_INTERVAL_MS=30000
# Overlap/re-look window subtracted from the cursor after every successful poll.
# Each poll re-queries the last POLL_OVERLAP of receive-time, so an email that
# wasn't returned by the poll that should have caught it (Gmail search-index lag,
# delivery timing, a one-off API hiccup) is re-seen on a later poll instead of
# being skipped forever. emailExists dedup makes the re-fetch idempotent. Applies
# to both Gmail and Outlook. Format: '10min', '30min', '1h'. Set '0h' to disable
# (restores the old advance-to-now behavior).
POLL_OVERLAP=10min
# Separate poll interval for Google Drive watcher
# GDRIVE_POLL_INTERVAL_MS=30000
# WORKFLOW_POLL_MS=2000
# STARTUP_DELAY_MS=15000
# MAX_NEW_PER_CYCLE=5
# EMAIL_WATCHER_METRICS_PORT=9465

# Comma-separated accountant/bookkeeper addresses — their non-invoice mail is skipped (intent gate)
ACCOUNTANT_EMAILS=accountant@example.com

# Business identifiers (for document-classifier owner field).
# These must match the buyer data in test PDFs (tests/test_data/*.pdf).
# Test PDFs use: Testlab s.r.o., ICO 12345678, DIC 2099999999, IC DPH SK2099999999
BUSINESS_COMPANY_NAME=Testlab s.r.o.
BUSINESS_TAX_IDS=SK2099999999
BUSINESS_CRN=12345678
BUSINESS_LICENSE_PLATES=BA000AA
# Business-owner label: Paperless tag name and Telegram command for business-owned docs.
# Also title-cased in Telegram notification display (e.g. "techlab" → "Techlab").
# Read by pa-worker (scan/email tags) AND the gdrive-poller (the watch folder whose
# name equals this value maps to the `business` owner role).
# Change to match your own company/project label if deploying independently.
OWNER_BUSINESS_LABEL=techlab

# OpenTelemetry (Claude Code native telemetry)
# Default: http://alloy:4317 (local Alloy sidecar or host Alloy)
# OTEL_ENDPOINT=http://alloy:4317
# OTEL_METRIC_INTERVAL=10000

# Volume data directory (production: NAS path via Komodo, local: ./data)
PA_DATA_DIR=./data

# PDF decryption (bank account statements)
BANK_PDF_PASSWORD=

# checker-mcp: comma-separated bank account numbers to skip as payroll
# (food stamps, salary). Matched as substring against the raw statement
# block, so partial account numbers work. Empty = no skip.
# SKIP_PAYROLL_ACCOUNTS=2938452410,1234567890

# checker-mcp: comma-separated, case-insensitive document-title prefixes whose
# unmatched invoices count as accrual income in /pl (before a bank statement
# confirms the payment). Empty = no accrual fallback. e.g. PL_INCOME_PREFIXES=sygic
# PL_INCOME_PREFIXES=sygic

# GDrive watcher
# Nested intake root folder name (optional). When set, watch folders are root/owner/bucket (3-level).
# When unset, watch folders are owner/bucket (2-level, backward-compatible).
GDRIVE_ROOT=_documents_intake
# Comma-separated owner folder names (falls back to GDRIVE_LEVEL1 if unset)
GDRIVE_OWNERS=testcompany,personal
# Comma-separated bucket folder names (falls back to GDRIVE_LEVEL2 if unset)
# Values must be from the supported set: accounting, documents
GDRIVE_BUCKETS=accounting,documents
GDRIVE_MCP_URL=http://gmail-mcp:8000/mcp

# Gmail client_secret.json file path (local dev — production uses GOOGLE_CLIENT_SECRET_JSON env var)
GMAIL_CLIENT_SECRET_FILE=./data/gmail/client_secret.json

# ─────────────────────────────────────────────────────────────────────────────
# Tuning knobs — read by source code with built-in defaults.
# NOT wired through docker-compose.yml. To override, you must add the var to
# both this .env AND the appropriate `environment:` block in docker-compose.yml
# (and to komodo.toml for production).
# ─────────────────────────────────────────────────────────────────────────────

# workflow-mcp / workflow-core
# WORKFLOW_MCP_PORT=8003                          # workflow-mcp.ts:30
# MAX_JOB_RETRIES=3                               # workflow-db.ts:327
# STALE_JOB_MINUTES=5                             # workflow-core.ts:174 (jobs stuck > N min are reaped)
# EMAIL_DB_PATH=/mnt/shared_configs/personal-assistant/email-watcher/emails.db
                                                  # workflow-mcp.ts:249 — only used by workflow-mcp's
                                                  # email lookup tool; runtime DB path comes from DB_PATH

# gdrive-poller
# GDRIVE_DB_PATH=/data/gdrive-watcher/gdrive.db   # pollers/gdrive-poller/src/main.ts (volume name kept as email-watcher/gdrive-watcher for backwards compat with on-disk audit DBs)
# GDRIVE_STARTUP_DELAY_MS=20000                   # pollers/gdrive-poller/src/main.ts
# GDRIVE_MAX_NEW_PER_CYCLE=5                      # pollers/gdrive-poller/src/main.ts

# file-ops / invoice-worker downloads
# DOWNLOADS_DIR=/workspace/downloads              # file-ops.ts:25 (file-ops MCP scope root)
# DOWNLOAD_DIR=/workspace/downloads               # invoice-worker.ts:249,1161 (singular — separate var, same default)

# invoice-worker → paperless-mcp
# PAPERLESS_MCP_URL=http://paperless-mcp:3000/mcp # invoice-worker.ts:149
